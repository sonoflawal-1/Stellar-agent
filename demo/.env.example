# ── Stellar network ───────────────────────────────────────────────────────────
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Contract addresses (testnet) ──────────────────────────────────────────────
# Circle's canonical testnet USDC SAC on Stellar (from x402-stellar token catalog).
USDC_TOKEN_CONTRACT=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
AGENT_IDENTITY_CONTRACT=CAMPXYFZJTIPEVOPOAZPRG5OHXKNBDPGTPRCOIO4LVPGEM4TONPY65A5
AGENTIC_COMMERCE_CONTRACT=CD2KWU7IE74Z2QKVP3FQ67J46XHNMGIDTNKXVWE7ZNVRC7T6UH46GQXE

# ── x402 facilitator ──────────────────────────────────────────────────────────
# Generate via: curl https://channels.openzeppelin.com/testnet/gen
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_FACILITATOR_API_KEY=
# Aliases consumed by seller-agent.ts / marcPaywall
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
FACILITATOR_API_KEY=

# ── Agent registry ────────────────────────────────────────────────────────────
REGISTRY_URL=http://localhost:4500
# Optional — leave blank to disable registry auth
REGISTRY_API_KEY=

# ── AI provider ───────────────────────────────────────────────────────────────
# Required by seller-researcher. Get a free key at https://console.groq.com
GROQ_API_KEY=

# ── Seller (lifecycle / seller-agent.ts) ──────────────────────────────────────
# Generate with: stellar keys generate seller --network testnet --fund
SELLER_SECRET=
SELLER_PUBKEY=
SELLER_PORT=4402
SELLER_SERVICE_PRICE=$0.01

# ── Buyer (lifecycle / buyer-agent.ts / cancel-flow.ts) ──────────────────────
# Generate with: stellar keys generate buyer --network testnet --fund
BUYER_SECRET=
# Optional polling tuning
BUYER_POLL_BASE_MS=2000
BUYER_POLL_MULTIPLIER=2
BUYER_POLL_MAX_ATTEMPTS=10
BUYER_POLL_CAP_MS=30000

# ── Job ID (seller-agent.ts deliverable submission) ───────────────────────────
JOB_ID=

