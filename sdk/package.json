{
  "name": "marc-stellar-sdk",
  "version": "0.1.0",
  "description": "Commerce layer SDK for MARC on Stellar — typed helpers for agent_identity + agentic_commerce contracts, plus x402-stellar re-exports.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "browser": "dist/browser.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/browser.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && npm run build:browser",
    "build:browser": "esbuild src/browser.ts --bundle --platform=browser --target=es2022 --format=esm --outfile=dist/browser.js --sourcemap && tsc --project tsconfig.browser.json --declaration --emitDeclarationOnly --outDir dist",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "@x402/express": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "@x402/stellar": "^2.9.0"
  },
  "peerDependencies": {
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.23.1",
    "typescript": "^5.6.0"
  }
}
