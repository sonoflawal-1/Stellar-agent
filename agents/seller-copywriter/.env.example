# Copy from ../../demo/.env and add:
SELLER_SECRET=        # this seller's Stellar secret key
AGENT_ID=seller-copywriter   # change per seller folder
PUBLIC_URL=           # public-facing base URL (default: http://localhost:PORT)
# Example for ngrok: PUBLIC_URL=https://abc123.ngrok.io
# If unset, generated sites are served locally at http://localhost:PORT/output/job-{id}.md
